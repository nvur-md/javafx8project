<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="unischool.controllers.AdminController"
            stylesheets="@../css/style.css"
            prefHeight="750.0" prefWidth="1200.0">

    <!-- TOP : Barre de titre -->
    <top>
        <VBox style="-fx-background-color: #2c3e50; -fx-padding: 15 20;">
            <HBox alignment="CENTER_LEFT" spacing="20.0">
                <Label text="👑 UniSchool - Administration" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="userLabel" text="👤 Admin" style="-fx-text-fill: #ecf0f1; -fx-font-size: 14px;"/>
                <Button text="🔄 Rafraîchir" onAction="#handleRefresh" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5px; -fx-padding: 8 15;"/>
                <Button text="🔓 Déconnexion" onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5px; -fx-padding: 8 15;"/>
            </HBox>
        </VBox>
    </top>

    <!-- CENTER : TabPane -->
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" style="-fx-padding: 10;">

            <!-- ONGLET 1 : GESTION ACADÉMIQUE -->
            <Tab text="📚 Gestion Académique" closable="false">
                <VBox spacing="15" style="-fx-padding: 20;">
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <Label text="📋 Filtrer par :" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                        <ComboBox fx:id="filiereFiltreCombo" promptText="Toutes les filières" prefWidth="200"/>
                        <ComboBox fx:id="anneeFiltreCombo" promptText="Toutes les années" prefWidth="150"/>
                        <Button text="🔍 Filtrer" onAction="#handleFiltrerEtudiants" styleClass="button-info"/>
                        <Button text="🔄 Tout afficher" onAction="#handleAfficherTousEtudiants" styleClass="button-secondary"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="👥 Total : " style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>
                        <Label fx:id="totalEtudiantsFiltres" text="0" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
                    </HBox>

                    <HBox spacing="10">
                        <Button text="➕ Ajouter" onAction="#handleAjouterEtudiant" styleClass="button-primary"/>
                        <Button text="✏️ Modifier" onAction="#handleModifierEtudiant" styleClass="button-warning"/>
                        <Button text="🗑️ Supprimer" onAction="#handleSupprimerEtudiant" styleClass="button-danger"/>
                        <Button text="📝 Gérer les absences" onAction="#handleGererAbsences" styleClass="button-info"/>
                    </HBox>

                    <TableView fx:id="etudiantTable" prefHeight="300">
                        <columns>
                            <TableColumn fx:id="etudiantIdCol" text="ID" prefWidth="50"/>
                            <TableColumn fx:id="etudiantNomCol" text="Nom" prefWidth="130"/>
                            <TableColumn fx:id="etudiantPrenomCol" text="Prénom" prefWidth="130"/>
                            <TableColumn fx:id="etudiantEmailCol" text="Email" prefWidth="180"/>
                            <TableColumn fx:id="etudiantFiliereCol" text="Filière" prefWidth="140"/>
                            <TableColumn fx:id="etudiantAnneeCol" text="Année" prefWidth="70"/>
                            <TableColumn fx:id="etudiantAbsencesCol" text="📋 Absences" prefWidth="90"/>
                            <TableColumn fx:id="etudiantMoyenneCol" text="Moyenne" prefWidth="80"/>
                            <TableColumn fx:id="etudiantStatutCol" text="Statut" prefWidth="80"/>
                        </columns>
                    </TableView>

                    <Accordion>
                        <panes>
                            <TitledPane text="📋 Détails de l'étudiant sélectionné" expanded="false">
                                <content>
                                    <VBox spacing="10" style="-fx-padding: 15;">
                                        <GridPane hgap="20" vgap="10">
                                            <Label text="Étudiant :" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
                                            <Label fx:id="detailsEtudiantNom" text="Aucun étudiant sélectionné" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                            <Label text="Filière :" GridPane.columnIndex="2" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
                                            <Label fx:id="detailsEtudiantFiliere" text="-" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                                            <Label text="Moyenne :" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
                                            <Label fx:id="detailsEtudiantMoyenne" text="-" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                            <Label text="Mention :" GridPane.columnIndex="2" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
                                            <Label fx:id="detailsEtudiantMention" text="-" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                                            <Label text="Absences :" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;"/>
                                            <Label fx:id="detailsEtudiantAbsences" text="-" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                        </GridPane>

                                        <Separator/>

                                        <Label text="📝 Relevé de notes" style="-fx-font-weight: bold;"/>
                                        <TableView fx:id="detailsNotesTable" prefHeight="150">
                                            <columns>
                                                <TableColumn text="Matière" prefWidth="150"/>
                                                <TableColumn text="Note" prefWidth="80"/>
                                                <TableColumn text="Coeff" prefWidth="60"/>
                                                <TableColumn text="Points" prefWidth="80"/>
                                                <TableColumn text="Date" prefWidth="100"/>
                                                <TableColumn text="Appréciation" prefWidth="150"/>
                                            </columns>
                                        </TableView>
                                    </VBox>
                                </content>
                            </TitledPane>
                        </panes>
                    </Accordion>
                </VBox>
            </Tab>

            <!-- ONGLET 2 : ENSEIGNANTS -->
            <Tab text="👨‍🏫 Enseignants" closable="false">
                <VBox spacing="15" style="-fx-padding: 20;">
                    <Label text="👨‍🏫 Gestion des Enseignants" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

                    <!-- Filtres -->
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <Label text="📋 Filtrer par :" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                        <ComboBox fx:id="enseignantFiliereFiltre" promptText="Toutes les filières" prefWidth="200"/>
                        <ComboBox fx:id="enseignantMatiereFiltre" promptText="Toutes les matières" prefWidth="200"/>
                        <Button text="🔍 Filtrer" onAction="#handleFiltrerEnseignants" styleClass="button-info"/>
                        <Button text="🔄 Tout afficher" onAction="#handleAfficherTousEnseignants" styleClass="button-secondary"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="👥 Total : " style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>
                        <Label fx:id="totalEnseignantsFiltres" text="0" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
                    </HBox>

                    <!-- Boutons CRUD -->
                    <HBox spacing="10">
                        <Button text="➕ Ajouter" onAction="#handleAjouterEnseignant" styleClass="button-primary"/>
                        <Button text="✏️ Modifier" onAction="#handleModifierEnseignant" styleClass="button-warning"/>
                        <Button text="🗑️ Supprimer" onAction="#handleSupprimerEnseignant" styleClass="button-danger"/>
                        <Button text="📋 Assigner une matière" onAction="#handleAssignerMatiere" styleClass="button-info"/>
                    </HBox>

                    <!-- Tableau des enseignants -->
                    <TableView fx:id="enseignantTable" prefHeight="400">
                        <columns>
                            <TableColumn fx:id="enseignantIdCol" text="ID" prefWidth="50"/>
                            <TableColumn fx:id="enseignantNomCol" text="Nom" prefWidth="150"/>
                            <TableColumn fx:id="enseignantPrenomCol" text="Prénom" prefWidth="150"/>
                            <TableColumn fx:id="enseignantEmailCol" text="Email" prefWidth="200"/>
                            <TableColumn fx:id="enseignantFiliereCol" text="Filière" prefWidth="150"/>
                            <TableColumn fx:id="enseignantSpecialiteCol" text="Spécialité" prefWidth="150"/>
                            <TableColumn fx:id="enseignantStatutCol" text="Statut" prefWidth="100"/>
                        </columns>
                    </TableView>

                    <Label fx:id="enseignantStatusLabel" text="💡 Sélectionnez un enseignant pour le modifier ou le supprimer" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d; -fx-padding: 5px;"/>
                </VBox>
            </Tab>

            <!-- ONGLET 3 : EMPLOI DU TEMPS -->
            <Tab text="📅 Emploi du temps" closable="false">
                <VBox spacing="15" style="-fx-padding: 20;">
                    <Label text="📅 Gestion de l'Emploi du Temps" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

                    <!-- Filtres -->
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <Label text="📋 Filière :" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <ComboBox fx:id="edtFiliereCombo" promptText="Sélectionner une filière" prefWidth="200"/>
                        <Label text="📋 Année :" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <ComboBox fx:id="edtAnneeCombo" promptText="Sélectionner une année" prefWidth="150"/>
                        <Label text="📋 Semestre :" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <ComboBox fx:id="edtSemestreCombo" promptText="Semestre" prefWidth="150"/>
                        <Button text="📊 Afficher" onAction="#handleAfficherEmploiDuTemps" styleClass="button-primary"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="📋 Total cours : " style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>
                        <Label fx:id="totalCoursLabel" text="0" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
                    </HBox>

                    <!-- Boutons CRUD -->
                    <HBox spacing="10">
                        <Button text="➕ Ajouter" onAction="#handleAjouterEmploiDuTemps" styleClass="button-primary"/>
                        <Button text="✏️ Modifier" onAction="#handleModifierEmploiDuTemps" styleClass="button-warning"/>
                        <Button text="🗑️ Supprimer" onAction="#handleSupprimerEmploiDuTemps" styleClass="button-danger"/>
                        <Button text="📋 Exporter" onAction="#handleExporterEmploiDuTemps" styleClass="button-success"/>
                    </HBox>

                    <!-- Tableau EDT -->
                    <TableView fx:id="emploiDuTempsTable" prefHeight="400">
                        <columns>
                            <TableColumn fx:id="edtJourCol" text="Jour" prefWidth="100"/>
                            <TableColumn fx:id="edtHoraireCol" text="Horaire" prefWidth="120"/>
                            <TableColumn fx:id="edtMatiereCol" text="Matière" prefWidth="200"/>
                            <TableColumn fx:id="edtEnseignantCol" text="Enseignant" prefWidth="200"/>
                            <TableColumn fx:id="edtSalleCol" text="Salle" prefWidth="100"/>
                            <TableColumn fx:id="edtTypeCol" text="Type" prefWidth="100"/>
                        </columns>
                    </TableView>

                    <Label fx:id="edtStatusLabel" text="💡 Sélectionnez un cours pour le modifier ou le supprimer" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d; -fx-padding: 5px;"/>
                </VBox>
            </Tab>

            <!-- ONGLET 4 : NOTES -->
            <Tab text="📊 Notes" closable="false">
                <VBox spacing="15" style="-fx-padding: 20;">
                    <Label text="📊 Gestion des Notes" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

                    <!-- Informations et boutons -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="➕ Ajouter une note" onAction="#handleAjouterNote" styleClass="button-success"/>
                        <Button text="✏️ Modifier" onAction="#handleModifierNote" styleClass="button-warning"/>
                        <Button text="🗑️ Supprimer" onAction="#handleSupprimerNote" styleClass="button-danger"/>
                        <Button text="📥 Export CSV" onAction="#handleExporterNotesCSV" styleClass="button-primary"/>
                    </HBox>

                    <!-- Tableau des notes -->
                    <TableView fx:id="notesTable" prefHeight="400">
                        <columns>
                            <TableColumn fx:id="noteIdCol" text="ID" prefWidth="50"/>
                            <TableColumn fx:id="noteEtudiantCol" text="Étudiant" prefWidth="150"/>
                            <TableColumn fx:id="noteMatiereCol" text="Matière" prefWidth="150"/>
                            <TableColumn fx:id="noteValeurCol" text="Note" prefWidth="80"/>
                            <TableColumn fx:id="noteCoeffCol" text="Coeff" prefWidth="60"/>
                            <TableColumn fx:id="notePointsCol" text="Points" prefWidth="80"/>
                            <TableColumn fx:id="noteTypeCol" text="Type" prefWidth="100"/>
                            <TableColumn fx:id="noteDateCol" text="Date" prefWidth="100"/>
                            <TableColumn fx:id="noteAppreciationCol" text="Appréciation" prefWidth="180"/>
                            <TableColumn fx:id="noteValideeCol" text="Validée" prefWidth="80"/>
                        </columns>
                    </TableView>

                    <Label fx:id="notesStatusLabel" text="💡 Sélectionnez une note pour la modifier ou la supprimer" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d; -fx-padding: 5px;"/>
                </VBox>
            </Tab>

            <!-- ONGLET 5 : COMMUNICATION -->
            <Tab text="✉️ Communication" closable="false">
                <VBox spacing="15" style="-fx-padding: 20;">
                    <Label text="✉️ Envoi de Messages" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

                    <HBox spacing="15">
                        <Label text="📋 Destinataires :" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <ComboBox fx:id="destinataireTypeCombo" prefWidth="200" promptText="Type de destinataire"/>
                        <ComboBox fx:id="destinataireFiliereCombo" promptText="Filière..." prefWidth="150"/>
                        <ComboBox fx:id="destinataireAnneeCombo" promptText="Année..." prefWidth="150"/>
                    </HBox>

                    <Label text="📝 Objet :" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <TextField fx:id="messageObjetField" promptText="Saisissez l'objet du message..."/>

                    <Label text="📝 Message :" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <TextArea fx:id="messageContentArea" promptText="Saisissez votre message ici..." prefHeight="120"/>

                    <Label fx:id="destinataireAffiche" text="Aucun destinataire sélectionné" style="-fx-text-fill: #7f8c8d; -fx-font-style: italic;"/>

                    <HBox spacing="10">
                        <Button text="📤 Envoyer" onAction="#handleEnvoyerMessage" styleClass="button-primary"/>
                        <Button text="🗑️ Effacer" styleClass="button-secondary"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="✉️ Messages envoyés : " style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                        <Label fx:id="messagesEnvoyesLabel" text="0" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
                    </HBox>

                    <Separator/>

                    <Label text="📋 Historique des messages" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <TableView fx:id="messagesTable" prefHeight="200">
                        <columns>
                            <TableColumn fx:id="msgDateCol" text="Date" prefWidth="150"/>
                            <TableColumn fx:id="msgExpediteurCol" text="Expéditeur" prefWidth="150"/>
                            <TableColumn fx:id="msgDestinataireCol" text="Destinataire" prefWidth="200"/>
                            <TableColumn fx:id="msgObjetCol" text="Objet" prefWidth="200"/>
                            <TableColumn fx:id="msgContenuCol" text="Message" prefWidth="300"/>
                            <TableColumn fx:id="msgLuCol" text="Lu" prefWidth="80"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- ONGLET 6 : STATISTIQUES -->
            <Tab text="📈 Statistiques" closable="false">
                <VBox spacing="15" style="-fx-padding: 20;">
                    <Label text="📈 Tableau de Bord Statistique" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

                    <GridPane hgap="15" vgap="15">
                        <VBox style="-fx-background-color: #3498db; -fx-padding: 20; -fx-background-radius: 10;" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="👥" style="-fx-font-size: 30px;"/>
                            <Label fx:id="statTotalEtudiants" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Label text="Étudiants" style="-fx-font-size: 14px; -fx-text-fill: #ecf0f1;"/>
                        </VBox>
                        <VBox style="-fx-background-color: #27ae60; -fx-padding: 20; -fx-background-radius: 10;" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="👨‍🏫" style="-fx-font-size: 30px;"/>
                            <Label fx:id="statTotalEnseignants" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Label text="Enseignants" style="-fx-font-size: 14px; -fx-text-fill: #ecf0f1;"/>
                        </VBox>
                        <VBox style="-fx-background-color: #e67e22; -fx-padding: 20; -fx-background-radius: 10;" GridPane.columnIndex="2" GridPane.rowIndex="0">
                            <Label text="📚" style="-fx-font-size: 30px;"/>
                            <Label fx:id="statTotalMatieres" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Label text="Matières" style="-fx-font-size: 14px; -fx-text-fill: #ecf0f1;"/>
                        </VBox>
                        <VBox style="-fx-background-color: #9b59b6; -fx-padding: 20; -fx-background-radius: 10;" GridPane.columnIndex="3" GridPane.rowIndex="0">
                            <Label text="📝" style="-fx-font-size: 30px;"/>
                            <Label fx:id="statTotalNotes" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Label text="Notes" style="-fx-font-size: 14px; -fx-text-fill: #ecf0f1;"/>
                        </VBox>

                        <VBox style="-fx-background-color: #1abc9c; -fx-padding: 20; -fx-background-radius: 10;" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="✅" style="-fx-font-size: 30px;"/>
                            <Label fx:id="statTauxReussite" text="0%" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Label text="Taux de réussite" style="-fx-font-size: 14px; -fx-text-fill: #ecf0f1;"/>
                        </VBox>
                        <VBox style="-fx-background-color: #e74c3c; -fx-padding: 20; -fx-background-radius: 10;" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="📊" style="-fx-font-size: 30px;"/>
                            <Label fx:id="statMoyenneGenerale" text="0.00" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Label text="Moyenne générale" style="-fx-font-size: 14px; -fx-text-fill: #ecf0f1;"/>
                        </VBox>
                        <VBox style="-fx-background-color: #f39c12; -fx-padding: 20; -fx-background-radius: 10;" GridPane.columnIndex="2" GridPane.rowIndex="1">
                            <Label text="📋" style="-fx-font-size: 30px;"/>
                            <Label fx:id="statTotalAbsences" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Label text="Total absences" style="-fx-font-size: 14px; -fx-text-fill: #ecf0f1;"/>
                        </VBox>
                        <VBox style="-fx-background-color: #2ecc71; -fx-padding: 20; -fx-background-radius: 10;" GridPane.columnIndex="3" GridPane.rowIndex="1">
                            <Label text="🏆" style="-fx-font-size: 30px;"/>
                            <Label fx:id="statMeilleurEtudiant" text="-" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Label text="Meilleur étudiant" style="-fx-font-size: 14px; -fx-text-fill: #ecf0f1;"/>
                        </VBox>
                    </GridPane>

                    <Separator/>

                    <HBox spacing="20">
                        <VBox spacing="10" HBox.hgrow="ALWAYS">
                            <Label text="📊 Répartition par filière" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                            <ListView fx:id="filiereListView" prefHeight="120"/>
                        </VBox>
                        <VBox spacing="10" HBox.hgrow="ALWAYS">
                            <Label text="📊 Répartition des notes" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                            <ListView fx:id="notesRepartitionListView" prefHeight="120"/>
                        </VBox>
                    </HBox>
                </VBox>
            </Tab>
        </TabPane>
    </center>

    <!-- BOTTOM : Barre de statut -->
    <bottom>
        <HBox style="-fx-background-color: #ecf0f1; -fx-padding: 8 20;">
            <Label text="✅ Prêt" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel" text="Connecté en tant qu'Administrateur" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
        </HBox>
    </bottom>
</BorderPane>