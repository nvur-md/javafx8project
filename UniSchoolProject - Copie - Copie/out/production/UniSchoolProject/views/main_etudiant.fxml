<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="unischool.controllers.EtudiantController"
            stylesheets="@../css/style.css"
            prefHeight="750.0" prefWidth="1200.0">

    <!-- TOP : Barre de titre -->
    <top>
        <VBox style="-fx-background-color: #2c3e50; -fx-padding: 15 20;">
            <HBox alignment="CENTER_LEFT" spacing="20.0">
                <Label text="🎓 UniSchool - Étudiant" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="userLabel" text="👤 Étudiant" style="-fx-text-fill: #ecf0f1; -fx-font-size: 14px;"/>
                <Button text="🔄 Rafraîchir" onAction="#handleRefresh" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5px; -fx-padding: 8 15;"/>
                <Button text="🔓 Déconnexion" onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5px; -fx-padding: 8 15;"/>
            </HBox>
        </VBox>
    </top>

    <!-- CENTER : TabPane -->
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" style="-fx-padding: 10;">

            <!-- ============================================================
                 ONGLET 1 : MON BULLETIN
                 ============================================================ -->
            <Tab text="📊 Mon Bulletin" closable="false">
                <VBox spacing="20" style="-fx-padding: 20;">

                    <Label text="📊 Mon Bulletin Scolaire" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

                    <!-- Carte d'identité -->
                    <GridPane hgap="20" vgap="10" style="-fx-background-color: #ecf0f1; -fx-padding: 20; -fx-background-radius: 10;">
                        <Label text="👤 Étudiant :" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
                        <Label fx:id="etudiantNomLabel" text="-" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <Label text="📚 Filière :" GridPane.columnIndex="2" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
                        <Label fx:id="etudiantFiliereLabel" text="-" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                        <Label text="📅 Année :" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
                        <Label fx:id="etudiantAnneeLabel" text="-" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        <Label text="🎯 Matricule :" GridPane.columnIndex="2" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
                        <Label fx:id="etudiantMatriculeLabel" text="-" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                    </GridPane>

                    <!-- Statistiques rapides -->
                    <GridPane hgap="20" vgap="10">
                        <VBox style="-fx-background-color: #3498db; -fx-padding: 15; -fx-background-radius: 10;" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="📊" style="-fx-font-size: 24px;"/>
                            <Label fx:id="moyenneGeneraleLabel" text="0.00" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Label text="Moyenne" style="-fx-font-size: 12px; -fx-text-fill: #ecf0f1;"/>
                        </VBox>
                        <VBox style="-fx-background-color: #27ae60; -fx-padding: 15; -fx-background-radius: 10;" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="🏆" style="-fx-font-size: 24px;"/>
                            <Label fx:id="mentionLabel" text="-" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Label text="Mention" style="-fx-font-size: 12px; -fx-text-fill: #ecf0f1;"/>
                        </VBox>
                        <VBox style="-fx-background-color: #e67e22; -fx-padding: 15; -fx-background-radius: 10;" GridPane.columnIndex="2" GridPane.rowIndex="0">
                            <Label text="📋" style="-fx-font-size: 24px;"/>
                            <Label fx:id="totalAbsencesLabel" text="0" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Label text="Absences" style="-fx-font-size: 12px; -fx-text-fill: #ecf0f1;"/>
                        </VBox>
                        <VBox style="-fx-background-color: #9b59b6; -fx-padding: 15; -fx-background-radius: 10;" GridPane.columnIndex="3" GridPane.rowIndex="0">
                            <Label text="📝" style="-fx-font-size: 24px;"/>
                            <Label fx:id="totalNotesLabel" text="0" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Label text="Notes" style="-fx-font-size: 12px; -fx-text-fill: #ecf0f1;"/>
                        </VBox>
                    </GridPane>

                    <Separator/>

                    <!-- Liste des notes -->
                    <Label text="📝 Mes Notes" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

                    <TableView fx:id="notesTable" prefHeight="300">
                        <columns>
                            <TableColumn fx:id="noteIdCol" text="ID" prefWidth="50"/>
                            <TableColumn fx:id="noteMatiereCol" text="Matière" prefWidth="200"/>
                            <TableColumn fx:id="noteValeurCol" text="Note" prefWidth="80"/>
                            <TableColumn fx:id="noteCoeffCol" text="Coeff" prefWidth="60"/>
                            <TableColumn fx:id="notePointsCol" text="Points" prefWidth="80"/>
                            <TableColumn fx:id="noteTypeCol" text="Type" prefWidth="100"/>
                            <TableColumn fx:id="noteDateCol" text="Date" prefWidth="100"/>
                            <TableColumn fx:id="noteAppreciationCol" text="Appréciation" prefWidth="200"/>
                            <TableColumn fx:id="noteValideeCol" text="Validée" prefWidth="80"/>
                        </columns>
                    </TableView>

                    <!-- ============================================================
     MATIÈRES - AGRANDI ET AÉRÉ
     ============================================================ -->
                    <VBox spacing="10" style="-fx-padding: 15 0 0 0;">
                        <Label text="📚 Mes matières" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                        <ListView fx:id="matieresListView" prefHeight="150"
                                  style="-fx-background-radius: 8px; -fx-border-color: #dcdde1; -fx-border-radius: 8px; -fx-border-width: 1px;">
                            <style>
                                .list-cell {
                                -fx-padding: 10 15;
                                -fx-font-size: 14px;
                                -fx-background-color: transparent;
                                -fx-border-color: transparent;
                                }
                                .list-cell:odd {
                                -fx-background-color: #f8f9fa;
                                }
                                .list-cell:even {
                                -fx-background-color: white;
                                }
                                .list-cell .text {
                                -fx-fill: #2c3e50;
                                }
                            </style>
                        </ListView>
                    </VBox>
                </VBox>
            </Tab>

            <!-- ============================================================
     ONGLET 2 : COMMUNICATION
     ============================================================ -->
            <Tab text="✉️ Communication" closable="false">
                <VBox spacing="15" style="-fx-padding: 20;">
                    <Label text="✉️ Communication" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <Label text="📋 Destinataire :" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                        <ComboBox fx:id="etudiantDestinataireCombo" prefWidth="250" promptText="Sélectionner un destinataire"/>
                    </HBox>

                    <Label text="📝 Objet :" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <TextField fx:id="etudiantMessageObjetField" promptText="Saisissez l'objet du message..."/>

                    <Label text="📝 Message :" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <TextArea fx:id="etudiantMessageContentArea" promptText="Saisissez votre message ici..." prefHeight="120"/>

                    <Label fx:id="etudiantDestinataireAffiche" text="Aucun destinataire sélectionné" style="-fx-text-fill: #7f8c8d; -fx-font-style: italic;"/>

                    <HBox spacing="10">
                        <Button text="📤 Envoyer" onAction="#handleEtudiantEnvoyerMessage" styleClass="button-primary"/>
                        <Button text="🗑️ Effacer" onAction="#handleEtudiantEffacerMessage" styleClass="button-secondary"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="✉️ Messages envoyés : " style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                        <Label fx:id="etudiantMessagesEnvoyesLabel" text="0" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
                    </HBox>

                    <Separator/>

                    <Label text="📋 Messages envoyés" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <TableView fx:id="etudiantMessagesTable" prefHeight="150">
                        <columns>
                            <TableColumn fx:id="etudiantMsgDateCol" text="Date" prefWidth="150"/>
                            <TableColumn fx:id="etudiantMsgExpediteurCol" text="Expéditeur" prefWidth="150"/>
                            <TableColumn fx:id="etudiantMsgDestinataireCol" text="Destinataire" prefWidth="200"/>
                            <TableColumn fx:id="etudiantMsgObjetCol" text="Objet" prefWidth="200"/>
                            <TableColumn fx:id="etudiantMsgContenuCol" text="Message" prefWidth="300"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>
        </TabPane>
    </center>

    <!-- BOTTOM : Barre de statut -->
    <bottom>
        <HBox style="-fx-background-color: #ecf0f1; -fx-padding: 8 20;">
            <Label text="✅ Prêt" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel" text="Connecté en tant qu'Étudiant" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
        </HBox>
    </bottom>
</BorderPane>